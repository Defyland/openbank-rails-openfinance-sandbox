{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/openbank-rails-openfinance-sandbox/docs/events/consent.revoked.v1.json",
  "title": "consent.revoked v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "developer_app_id", "consent_id", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "const": "consent.revoked" },
    "schema_version": { "type": "integer", "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "const": "openbank-sandbox" },
    "developer_app_id": { "type": "string" },
    "consent_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
