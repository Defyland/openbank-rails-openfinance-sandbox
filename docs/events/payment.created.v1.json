{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/openbank-rails-openfinance-sandbox/docs/events/payment.created.v1.json",
  "title": "payment.created v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "developer_app_id", "consent_id", "payment_id", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string", "pattern": "^evt_" },
    "event_type": { "type": "string", "const": "payment.created" },
    "schema_version": { "type": "integer", "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "const": "openbank-sandbox" },
    "developer_app_id": { "type": "string" },
    "consent_id": { "type": "string", "pattern": "^cns_" },
    "payment_id": { "type": "string", "pattern": "^pay_" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["status", "idempotency_key", "external_reference", "amount_cents", "currency", "debtor_account_id", "creditor"],
      "properties": {
        "status": { "type": "string", "const": "created" },
        "idempotency_key": { "type": "string" },
        "external_reference": { "type": "string" },
        "amount_cents": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string", "const": "BRL" },
        "debtor_account_id": { "type": "string" },
        "creditor": {
          "type": "object",
          "required": ["name", "document", "account"],
          "properties": {
            "name": { "type": "string" },
            "document": { "type": "string" },
            "account": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
