<% content_for :title, @developer_app.name %>

<header class="page-header">
  <div>
    <p class="eyebrow"><%= @developer_app.client_id %></p>
    <h1><%= @developer_app.name %></h1>
  </div>
  <%= link_to "Back", ops_developer_apps_path, class: "secondary-button" %>
</header>

<section class="detail-grid">
  <article class="panel">
    <h2>Profile</h2>
    <dl class="details">
      <dt>Status</dt>
      <dd><span class="status <%= @developer_app.status %>"><%= @developer_app.status %></span></dd>
      <dt>Webhook URL</dt>
      <dd><%= @developer_app.webhook_url %></dd>
      <dt>Active scenario</dt>
      <dd><%= @developer_app.active_scenario_code %></dd>
      <dt>Rate limit</dt>
      <dd><%= @developer_app.rate_limit_per_minute %>/min</dd>
    </dl>
  </article>

  <article class="panel">
    <h2>Recent consents</h2>
    <table>
      <tbody>
        <% @consents.each do |consent| %>
          <tr>
            <td><%= link_to consent.external_id, ops_consent_path(consent) %></td>
            <td><span class="status <%= consent.status %>"><%= consent.status %></span></td>
            <td><%= consent.sandbox_customer.full_name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </article>
</section>

<article class="panel">
  <div class="panel-header">
    <h2>Recent webhooks</h2>
    <%= link_to "All webhooks", ops_webhook_deliveries_path %>
  </div>
  <table>
    <thead>
      <tr>
        <th>Event</th>
        <th>Status</th>
        <th>Attempts</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% @webhook_deliveries.each do |delivery| %>
        <tr>
          <td><%= link_to delivery.event_type, ops_webhook_delivery_path(delivery) %></td>
          <td><span class="status <%= delivery.status %>"><%= delivery.status %></span></td>
          <td><%= delivery.attempts_count %></td>
          <td><%= l(delivery.created_at, format: :short) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>
