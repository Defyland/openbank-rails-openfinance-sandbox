<% content_for :title, "Payments" %>

<header class="page-header">
  <div>
    <p class="eyebrow">Payment initiation</p>
    <h1>Payments</h1>
  </div>
  <div class="filters">
    <% PaymentInitiation::STATUSES.each do |status| %>
      <%= link_to status, ops_payments_path(status: status), class: ("active" if @status == status) %>
    <% end %>
    <%= link_to "all", ops_payments_path, class: ("active" if @status.blank?) %>
  </div>
</header>

<article class="panel">
  <table>
    <thead>
      <tr>
        <th>Reference</th>
        <th>Status</th>
        <th>Amount</th>
        <th>App</th>
        <th>Processed</th>
      </tr>
    </thead>
    <tbody>
      <% @payments.each do |payment| %>
        <tr>
          <td><%= link_to payment.external_reference, ops_payment_path(payment) %></td>
          <td><span class="status <%= payment.status %>"><%= payment.status %></span></td>
          <td><%= number_to_currency(payment.amount_cents / 100.0, unit: payment.currency + " ") %></td>
          <td><%= payment.developer_app.name %></td>
          <td><%= payment.processed_at ? l(payment.processed_at, format: :short) : "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>
