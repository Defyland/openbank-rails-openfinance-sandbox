#!/usr/bin/env bash
set -euo pipefail

if ! command -v pg_restore >/dev/null 2>&1; then
  echo "pg_restore is required. Install PostgreSQL client tools before running restores." >&2
  exit 1
fi

database_url="${RESTORE_DATABASE_URL:-${DATABASE_URL:-}}"
if [[ -z "$database_url" ]]; then
  echo "DATABASE_URL or RESTORE_DATABASE_URL must be set." >&2
  exit 1
fi

if [[ -z "${BACKUP_FILE:-}" ]]; then
  echo "BACKUP_FILE must point to a pg_dump custom-format backup." >&2
  exit 1
fi

if [[ "${CONFIRM_RESTORE:-}" != "true" ]]; then
  echo "Refusing to restore without CONFIRM_RESTORE=true." >&2
  exit 1
fi

pg_restore \
  --clean \
  --if-exists \
  --exit-on-error \
  --no-owner \
  --no-acl \
  --dbname="$database_url" \
  "$BACKUP_FILE"

echo "Restored backup: $BACKUP_FILE"
